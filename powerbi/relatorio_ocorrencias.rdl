  <DataSources>
    <DataSource Name="PostgresChicago">
      <rd:SecurityType>Integrated</rd:SecurityType>
      <ConnectionProperties>
        <DataProvider>ODBC</DataProvider>
        <ConnectString>Dsn=ChicagoCrimes</ConnectString>
        <IntegratedSecurity>true</IntegratedSecurity>
      </ConnectionProperties>
      <rd:DataSourceID>46642848-1648-4fb5-a610-10c592b25f61</rd:DataSourceID>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="dsDistritos">
      <Query>
        <DataSourceName>PostgresChicago</DataSourceName>
        <CommandText>SELECT district, nome_district
FROM dbt_marts.dim_distrito
WHERE flag_versao_atual = true
ORDER BY district</CommandText>
      </Query>
      <Fields>
        <Field Name="district">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>district</DataField>
        </Field>
        <Field Name="nome_district">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_district</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsOcorrencias">
      <Query>
        <DataSourceName>PostgresChicago</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <Value>=Parameters!ano_inicial.Value</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=Parameters!ano_final.Value</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=Parameters!distrito.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    d.ano,
    d.numero_mes,
    d.nome_mes,
    g.nome_district,
    c.categoria_analitica,
    c.primary_type_atual                    AS tipo_crime,
    SUM(f.qtd_ocorrencia)                   AS ocorrencias,
    SUM(f.qtd_prisao)                       AS prisoes,
    ROUND(
        SUM(f.qtd_prisao)::numeric
        / NULLIF(SUM(f.qtd_ocorrencia), 0) * 100
    , 2)                                    AS taxa_prisao_pct
FROM dbt_marts.fct_ocorrencias f
JOIN dbt_marts.dim_data      d ON f.sk_data      = d.sk_data
JOIN dbt_marts.dim_geografia g ON f.sk_geografia = g.sk_geografia
JOIN dbt_marts.dim_crime     c ON f.sk_crime     = c.sk_crime
WHERE d.ano BETWEEN ? AND ?
  AND g.district = ?
GROUP BY d.ano, d.numero_mes, d.nome_mes, g.nome_district,
         c.categoria_analitica, c.primary_type_atual
ORDER BY d.ano, d.numero_mes, ocorrencias DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ano">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>ano</DataField>
        </Field>
        <Field Name="numero_mes">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>numero_mes</DataField>
        </Field>
        <Field Name="nome_mes">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_mes</DataField>
        </Field>
        <Field Name="nome_district">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_district</DataField>
        </Field>
        <Field Name="categoria_analitica">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>categoria_analitica</DataField>
        </Field>
        <Field Name="tipo_crime">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>tipo_crime</DataField>
        </Field>
        <Field Name="ocorrencias">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ocorrencias</DataField>
        </Field>
        <Field Name="prisoes">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>prisoes</DataField>
        </Field>
        <Field Name="taxa_prisao_pct">
          <rd:TypeName>System.Decimal</rd:TypeName>
          <DataField>taxa_prisao_pct</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
