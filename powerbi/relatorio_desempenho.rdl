  </DataSources>
  <DataSets>
    <DataSet Name="dsTiposCrime">
      <Query>
        <DataSourceName>PostgresChicago</DataSourceName>
        <CommandText>SELECT primary_type, nome_tipo_crime
FROM dbt_marts.dim_tipo_crime
WHERE sk_tipo_crime &lt;&gt; '-1'
ORDER BY nome_tipo_crime</CommandText>
      </Query>
      <Fields>
        <Field Name="primary_type">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>primary_type</DataField>
        </Field>
        <Field Name="nome_tipo_crime">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_tipo_crime</DataField>
        </Field>
      </Fields>
    </DataSet>
    <DataSet Name="dsDesempenho">
      <Query>
        <DataSourceName>PostgresChicago</DataSourceName>
        <QueryParameters>
          <QueryParameter Name="?">
            <Value>=Parameters!ano_inicial.Value</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=Parameters!ano_final.Value</Value>
          </QueryParameter>
          <QueryParameter Name="?">
            <Value>=Parameters!tipo_crime.Value</Value>
          </QueryParameter>
        </QueryParameters>
        <CommandText>SELECT
    m.ano,
    m.numero_mes,
    m.nome_mes,
    dt.nome_district,
    tc.nome_tipo_crime,
    tc.categoria_analitica,
    SUM(f.qtd_ocorrencias)  AS ocorrencias,
    SUM(f.qtd_prisoes)      AS prisoes,
    SUM(f.qtd_domesticos)   AS domesticos
FROM dbt_marts.fct_desempenho_mensal f
JOIN dbt_marts.dim_mes        m  ON f.sk_mes        = m.sk_mes
JOIN dbt_marts.dim_distrito   dt ON f.sk_distrito   = dt.sk_distrito
JOIN dbt_marts.dim_tipo_crime tc ON f.sk_tipo_crime = tc.sk_tipo_crime
WHERE m.ano BETWEEN ? AND ?
  AND tc.primary_type = ?
GROUP BY m.ano, m.numero_mes, m.nome_mes, dt.nome_district,
         tc.nome_tipo_crime, tc.categoria_analitica
ORDER BY m.ano, m.numero_mes, ocorrencias DESC</CommandText>
      </Query>
      <Fields>
        <Field Name="ano">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>ano</DataField>
        </Field>
        <Field Name="numero_mes">
          <rd:TypeName>System.Int32</rd:TypeName>
          <DataField>numero_mes</DataField>
        </Field>
        <Field Name="nome_mes">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_mes</DataField>
        </Field>
        <Field Name="nome_district">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_district</DataField>
        </Field>
        <Field Name="nome_tipo_crime">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>nome_tipo_crime</DataField>
        </Field>
        <Field Name="categoria_analitica">
          <rd:TypeName>System.String</rd:TypeName>
          <DataField>categoria_analitica</DataField>
        </Field>
        <Field Name="ocorrencias">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>ocorrencias</DataField>
        </Field>
        <Field Name="prisoes">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>prisoes</DataField>
        </Field>
        <Field Name="domesticos">
          <rd:TypeName>System.Int64</rd:TypeName>
          <DataField>domesticos</DataField>
        </Field>
      </Fields>
    </DataSet>
  </DataSets>
